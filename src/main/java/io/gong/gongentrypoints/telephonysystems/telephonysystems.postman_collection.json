{
	"info": {
		"name": "gong-entrypoints — telephonysystems",
		"description": "Triggers for the telephonysystems module entry points, exposed by the gong-entrypoints app. Requests are grouped into a folder per entrypoint. Set the active Postman Environment (telephonysystems.localhost) to point {{baseUrl}} at the running gong-entrypoints app (always localhost:8080).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "backfill",
			"description": "Entrypoint #1 — backfill marked TSs (zero-arg smoke test). Proves the whole request → Supervisor → troubleshooter loop works. Always 200.",
			"item": [
				{
					"name": "backfill — once (local)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/telephonysystems/backfill",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"telephonysystems",
								"backfill"
							]
						},
						"description": "Zero-arg smoke test targeting localhost:8097. Fires the backfill-marked-TSs troubleshooter on IngesterTelephonySystemsSupervisor. Expect 200 with body 'Backfilled <n> TSs'."
					},
					"response": []
				},
				{
					"name": "backfill — N times (loop=10)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/telephonysystems/backfill?loop=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"telephonysystems",
								"backfill"
							],
							"query": [
								{
									"key": "loop",
									"value": "10"
								}
							]
						},
						"description": "Fires the backfill N times (5s apart). Set loop to the desired count."
					},
					"response": []
				},
				{
					"name": "backfill — loop until stopped (loop=true)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/telephonysystems/backfill?loop=true",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"telephonysystems",
								"backfill"
							],
							"query": [
								{
									"key": "loop",
									"value": "true"
								}
							]
						},
						"description": "Loops until stopped. This request blocks until the stop request is sent."
					},
					"response": []
				},
				{
					"name": "backfill — stop loop",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/telephonysystems/backfill/stop",
							"host": [
