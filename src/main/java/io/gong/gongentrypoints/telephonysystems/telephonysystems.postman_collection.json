		{
			"name": "sync-job",
			"description": "Entrypoint #5 — High/Low-priority SyncJob (SQS) executor. The production periodic/backfill sync path (AbstractSyncJobMsgExecutor.execute, breakpoint line 80). execute() has no direct HTTP entry, so two on-demand routes reach it: run-chain-now (flips the scheduled event to now, most realistic) and send-message (puts a SyncJob JSON on the queue directly). Entrypoint #4 (Kafka TelephonyCallEventConsumer) has no troubleshooter route — use the process-call-event folder for the same downstream logic.",
			"item": [
				{
					"name": "run-chain-now — once",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/telephonysystems/sync-job/run-chain-now?company-id=9001&integration-id=9001&is-backfill=false",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"telephonysystems",
								"sync-job",
								"run-chain-now"
							],
							"query": [
								{
									"key": "company-id",
									"value": "9001"
								},
								{
									"key": "integration-id",
									"value": "9001"
								},
								{
									"key": "is-backfill",
									"value": "false",
									"description": "true routes to the low-priority (backfill) queue."
								}
							]
						},
						"description": "Variant A — flips the scheduled event's run-time to now so the chain enqueues a SyncJob on its own (most realistic). Reaches AbstractSyncJobMsgExecutor.execute() line 80. Expect 200."
					},
					"response": []
				},
